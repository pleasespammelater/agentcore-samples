# ─────────────────────────────────────────────────────────────────────────────
# Real-world example .env — Use Case 2 (Okta)
#
# Three Okta app registrations are used:
#   - FrontendApp (Web App)     — browser signs into this via Authorization
#                                 Code + PKCE
#   - AgentApp    (API Services) — audience-side for T_user; OAuth client for
#                                 OBO #1 (agent → gateway) via Token Exchange
#   - GatewayApp  (API Services) — audience-side for T_gateway; OAuth client
#                                 for OBO #2 (gateway → mock downstream) via
#                                 Token Exchange
#
# All three are registered fresh for this use case — no reuse from Use Case 1.
# ─────────────────────────────────────────────────────────────────────────────

# ── Okta ────────────────────────────────────────────────────────────────────
OKTA_DOMAIN=integrator-1234567.okta.com
OKTA_AUTH_SERVER_ID=default

# Audience of the default authorization server. Every token minted by this
# server carries this in its `aud` claim (Okta's convention). Both Runtime
# and Gateway configure this as their `allowedAudience`; the two are
# differentiated by scope (agent.access vs gateway.access) rather than
# audience. See ARCHITECTURE.md for the rationale.
OKTA_AUDIENCE=api://default

# Admin API token used by deploy/00_create_okta_apps.py for the automated
# setup path. Create one at Okta admin → Security → API → Tokens → Create
# Token. Leave blank if you're doing the manual setup path in IDP_SETUP.md.
# The token is NOT needed at runtime.
OKTA_ADMIN_TOKEN=

# ── Okta app registrations ──────────────────────────────────────────────────
# Frontend Web App (the user-facing OIDC client the browser signs into).
# Grant types: Authorization Code + Refresh Token, PKCE required.
FRONTEND_CLIENT_ID=0oaXXXXXXXXXXXXXXX
FRONTEND_CLIENT_SECRET=replace-me

# Agent API Services app (audience-side for T_user; OAuth client for OBO #1).
# Grant types: Token Exchange. DPoP must be OFF.
AGENT_CLIENT_ID=0oaYYYYYYYYYYYYYYY
AGENT_CLIENT_SECRET=replace-me

# Gateway API Services app (audience-side for T_gateway; OAuth client for OBO #2).
# Grant types: Token Exchange. DPoP must be OFF.
GATEWAY_CLIENT_ID=0oaZZZZZZZZZZZZZZZ
GATEWAY_CLIENT_SECRET=replace-me

# ── OAuth scopes ────────────────────────────────────────────────────────────
# What the frontend requests at sign-in. `openid profile email` fetches the
# user's identity; `agent.access` is the custom scope that authorizes the
# frontend to reach the agent. Quoted because it contains spaces — the
# `.env` file is read by both python-dotenv (which handles either form)
# and by `source .env` in your shell (which needs quoting for
# space-containing values).
UPSTREAM_SCOPE="openid profile email agent.access"

# What the agent requests via OBO #1 (audience is still api://default but
# scope narrows to gateway.access — which is what the Gateway checks for).
# Custom (non-OIDC) scope because Okta refuses `openid` / `profile` / `email`
# on Token Exchange (reason: openid_not_allowed_token_exchange).
GATEWAY_SCOPE=gateway.access

# What the Gateway requests via OBO #2 to reach the mock downstream API.
# Custom scope for the same reason as GATEWAY_SCOPE.
DOWNSTREAM_SCOPE=downstream.access

# ── Downstream mock API ─────────────────────────────────────────────────────
# The Gateway target's OpenAPI spec (gateway/downstream_openapi.json) points
# at this URL. httpbin.org/anything echoes the entire incoming request back
# as JSON so you can SEE the OBO'd token that the Gateway sent — perfect for
# a learning example. In production you'd point this at your own API.
DOWNSTREAM_URL=https://httpbin.org/anything

# ── Frontend ────────────────────────────────────────────────────────────────
FRONTEND_HOST=localhost
FRONTEND_PORT=8000
FRONTEND_SESSION_SECRET=generate-a-long-random-string-with-secrets-token-hex

# Full redirect URI — must be registered on the Frontend Web App in Okta.
# Okta requires http:// redirect URIs to use the literal hostname `localhost`.
FRONTEND_REDIRECT_URI=http://localhost:8000/auth/callback

# ── AWS ─────────────────────────────────────────────────────────────────────
AWS_REGION=us-west-2

# ── AgentCore Identity ──────────────────────────────────────────────────────
# Workload identity used by the agent's Runtime execution role for OBO #1.
AGENT_WORKLOAD_NAME=obo-uc2-okta-agent

# Credential provider used by the agent for OBO #1 (auths as AgentApp).
AGENT_OBO_PROVIDER_NAME=obo-uc2-okta-agent-actor

# Credential provider used by the Gateway for OBO #2 (auths as GatewayApp).
GATEWAY_OBO_PROVIDER_NAME=obo-uc2-okta-gateway-actor

# ── AgentCore Gateway ───────────────────────────────────────────────────────
# Logical name for the Gateway resource. Lower-case, hyphens OK.
GATEWAY_NAME=obo-uc2-okta-gateway

# Optional: bring-your-own Gateway service role. If unset, deploy/02_create_gateway.py
# auto-creates a role named AmazonBedrockAgentCoreGatewayRole-<GATEWAY_NAME>
# and writes the ARN back to this file.
GATEWAY_SERVICE_ROLE_ARN=

# Populated by deploy/02_create_gateway.py after creation. The agent uses
# this as its MCP endpoint URL.
GATEWAY_MCP_URL=

# ── AgentCore Runtime (the agent) ───────────────────────────────────────────
# CLI rules: <= 23 characters, must start with a letter, alphanumeric only
# (no underscores, no hyphens). Use camelCase to combine words.
AGENT_RUNTIME_NAME=oboUc2OktaAgent

# Populated by `agentcore status` after the agent is deployed.
AGENT_RUNTIME_INVOKE_URL=
