# ─────────────────────────────────────────────────────────────────────────────
# Real-world example .env — Use Case 2 (Entra)
#
# Three Entra app registrations are used:
#   - FrontendApp (browser signs into this)
#   - AgentApp    (audience for T_user; OAuth client for OBO #1, agent → gateway)
#   - GatewayApp  (audience for T_gateway; OAuth client for OBO #2, gateway → Graph)
#
# All three are registered fresh for this use case — no reuse from Use Case 1.
# ─────────────────────────────────────────────────────────────────────────────

# ── Entra ID ────────────────────────────────────────────────────────────────
TENANT_ID=00000000-0000-0000-0000-000000000000

# Frontend app registration (the user-facing OIDC client the browser signs into).
FRONTEND_CLIENT_ID=00000000-0000-0000-0000-000000000000
FRONTEND_CLIENT_SECRET=replace-me

# Agent app registration (audience for T_user; OAuth client for OBO #1).
AGENT_CLIENT_ID=00000000-0000-0000-0000-000000000000
AGENT_CLIENT_SECRET=replace-me

# Gateway app registration (audience for T_gateway; OAuth client for OBO #2).
GATEWAY_CLIENT_ID=00000000-0000-0000-0000-000000000000
GATEWAY_CLIENT_SECRET=replace-me

# Scope that the frontend requests on sign-in. Must be exposed by the agent app.
AGENT_SCOPE=api://00000000-0000-0000-0000-000000000000/access_as_user

# Scope the agent requests via OBO #1 (audienced at the Gateway app).
# Must be exposed by the gateway app.
GATEWAY_SCOPE=api://00000000-0000-0000-0000-000000000000/access_as_user

# Scope the gateway requests via OBO #2 (audienced at Microsoft Graph).
# Use .default — Entra will collect every Graph permission consented on the
# gateway app (User.Read after IDP_SETUP step 3).
GRAPH_SCOPE=https://graph.microsoft.com/.default

# ── Frontend ────────────────────────────────────────────────────────────────
FRONTEND_HOST=localhost
FRONTEND_PORT=8000
FRONTEND_SESSION_SECRET=generate-a-long-random-string-with-secrets-token-hex

# Full redirect URI — must be registered on the frontend app in Entra.
# Entra requires http:// redirect URIs to use the literal hostname 'localhost'.
FRONTEND_REDIRECT_URI=http://localhost:8000/auth/callback

# ── AWS ─────────────────────────────────────────────────────────────────────
AWS_REGION=us-west-2

# ── AgentCore Identity ──────────────────────────────────────────────────────
# Workload identity used by the agent's Runtime execution role for OBO #1.
AGENT_WORKLOAD_NAME=obo-uc2-entra-agent
# Credential provider used by the agent for OBO #1 (auths as AgentApp).
AGENT_OBO_PROVIDER_NAME=obo-uc2-entra-agent-actor

# Credential provider used by the Gateway for OBO #2 (auths as GatewayApp).
# No separate "gateway workload" — Gateway uses its own service role.
GATEWAY_OBO_PROVIDER_NAME=obo-uc2-entra-gateway-actor

# ── AgentCore Gateway ───────────────────────────────────────────────────────
# Logical name for the Gateway resource. Lower-case, hyphens OK.
GATEWAY_NAME=obo-uc2-entra-gateway

# Optional: bring-your-own Gateway service role. If unset, deploy/02_create_gateway.py
# auto-creates a role named AmazonBedrockAgentCoreGatewayRole-<GATEWAY_NAME>
# and writes the ARN back to this file.
GATEWAY_SERVICE_ROLE_ARN=

# Populated by deploy/02_create_gateway.py after creation. The agent uses this
# as its MCP endpoint URL.
GATEWAY_MCP_URL=

# ── AgentCore Runtime (the agent) ───────────────────────────────────────────
# CLI rules: ≤ 23 characters, must start with a letter, alphanumeric only
# (no underscores, no hyphens). Use camelCase to combine words.
AGENT_RUNTIME_NAME=oboUc2EntraAgent

# Populated by `agentcore status` after the agent is deployed.
AGENT_RUNTIME_INVOKE_URL=
