# ─────────────────────────────────────────────────────────────────────────────
# Real-world example .env — Use Case 1 (Okta)
#
# Two Okta app integrations: a Web App for the user-facing frontend, and a
# Service App for the middle-tier agent that performs the OBO exchange. The
# frontend and agent authenticate to Okta with different client credentials,
# and the user consents to the frontend once.
# ─────────────────────────────────────────────────────────────────────────────

# ── Okta ────────────────────────────────────────────────────────────────────
OKTA_DOMAIN=integrator-1234567.okta.com
OKTA_AUTH_SERVER_ID=default
OKTA_AUDIENCE=api://default

# Web App — user-facing OIDC client the browser signs into.
FRONTEND_CLIENT_ID=0oaXXXXXXXXXXXXXXX
FRONTEND_CLIENT_SECRET=replace-me

# Service App — middle-tier confidential client that does OBO (Token Exchange).
AGENT_CLIENT_ID=0oaYYYYYYYYYYYYYYY
AGENT_CLIENT_SECRET=replace-me

# Scope the frontend requests on behalf of the user.
UPSTREAM_SCOPE=openid profile email

# Scope the agent requests from Okta on the user's behalf via OBO.
# Must be a custom non-OIDC scope. Okta refuses to issue `openid` on Token
# Exchange (reason: openid_not_allowed_token_exchange) AND refuses non-openid
# OIDC scopes without `openid` (reason: openid_scope_required). A custom
# scope sidesteps both rules — it's also the realistic production pattern
# where the downstream token is for your own resource server.
#
# Define `agent.downstream` (or any name) as a custom scope on your Okta
# authorization server per IDP_SETUP.md Step 3a.
DOWNSTREAM_SCOPE=agent.downstream

# ── Frontend ────────────────────────────────────────────────────────────────
FRONTEND_HOST=localhost
FRONTEND_PORT=8000
FRONTEND_SESSION_SECRET=generate-a-long-random-string-with-secrets-token-hex

# Full redirect URI — must be registered on the Web App in Okta.
FRONTEND_REDIRECT_URI=http://localhost:8000/auth/callback

# ── AWS ─────────────────────────────────────────────────────────────────────
AWS_REGION=us-west-2

# ── AgentCore ───────────────────────────────────────────────────────────────
WORKLOAD_NAME=obo-usecase1-okta-realworld
ACTOR_PROVIDER_NAME=obo-uc1-okta-realworld-actor

# Agent runtime name (used by the AgentCore CLI as the project name).
# CLI rules: ≤ 23 characters, must start with a letter, alphanumeric only
# (no underscores, no hyphens). Use camelCase to combine words.
AGENT_RUNTIME_NAME=oboUc1OktaAgent

# Populated by the AgentCore CLI (`agentcore status`) after the agent is deployed.
AGENT_RUNTIME_INVOKE_URL=
