# Okta
OKTA_DOMAIN=integrator-0000000.okta.com
OKTA_AUTH_SERVER_ID=default
OKTA_AUDIENCE=api://default

# Native app — plays the frontend / user-facing OIDC client
NATIVE_APP_CLIENT_ID=0oaXXXXXXXXXXXXXXX
NATIVE_APP_CLIENT_SECRET=replace-me

# Service app — plays the middle-tier agent that performs OBO (API1)
SERVICE_APP_CLIENT_ID=0oaYYYYYYYYYYYYYYY
SERVICE_APP_CLIENT_SECRET=replace-me

# Scopes
UPSTREAM_SCOPE=openid
DOWNSTREAM_SCOPE=oboe2e.apiC.read

# AWS
AWS_REGION=us-west-2

# AgentCore names
WORKLOAD_NAME=obo-usecase1-okta
CLIENT_PROVIDER_NAME=obo-uc1-okta-client
ACTOR_PROVIDER_NAME=obo-uc1-okta-actor

# User identifier for the 3LO session
USER_ALIAS=demo-user
