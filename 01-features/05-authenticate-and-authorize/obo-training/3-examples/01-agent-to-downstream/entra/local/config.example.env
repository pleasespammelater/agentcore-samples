# Entra ID
TENANT_ID=00000000-0000-0000-0000-000000000000
AGENT_CLIENT_ID=00000000-0000-0000-0000-000000000000
AGENT_CLIENT_SECRET=replace-me
AGENT_SCOPE=api://00000000-0000-0000-0000-000000000000/access_as_user
GRAPH_SCOPE=https://graph.microsoft.com/User.Read

# AWS
AWS_REGION=us-west-2

# AgentCore names — used to identify the workload identity and credential providers.
WORKLOAD_NAME=obo-usecase1-entra
CLIENT_PROVIDER_NAME=obo-uc1-entra-client
ACTOR_PROVIDER_NAME=obo-uc1-entra-actor

# User identifier (any short string — AgentCore uses it to scope the 3LO session)
USER_ALIAS=demo-user
