# ─────────────────────────────────────────────────────────────────────────────
# Real-world example .env — Use Case 1 (Entra)
#
# Two Entra app registrations are used: a frontend (user-facing) and an agent
# (resource). They are configured separately so the frontend and agent can
# have different secrets and permissions.
# ─────────────────────────────────────────────────────────────────────────────

# ── Entra ID ────────────────────────────────────────────────────────────────
TENANT_ID=00000000-0000-0000-0000-000000000000

# Frontend app registration (the user-facing OIDC client the browser signs into).
FRONTEND_CLIENT_ID=00000000-0000-0000-0000-000000000000
FRONTEND_CLIENT_SECRET=replace-me

# Agent app registration (the middle-tier resource that does OBO).
AGENT_CLIENT_ID=00000000-0000-0000-0000-000000000000
AGENT_CLIENT_SECRET=replace-me

# Scope that the frontend requests. Must be exposed by the agent app.
AGENT_SCOPE=api://00000000-0000-0000-0000-000000000000/access_as_user

# Downstream Graph scope requested via OBO.
GRAPH_SCOPE=https://graph.microsoft.com/User.Read

# ── Frontend ────────────────────────────────────────────────────────────────
FRONTEND_HOST=localhost
FRONTEND_PORT=8000
FRONTEND_SESSION_SECRET=generate-a-long-random-string-with-secrets-token-hex

# Full redirect URI — must be registered on the frontend app in Entra.
# Entra requires http:// redirect URIs to use the literal hostname 'localhost'
# (not 127.0.0.1 or other IPs). Use https:// for any other host.
FRONTEND_REDIRECT_URI=http://localhost:8000/auth/callback

# ── AWS ─────────────────────────────────────────────────────────────────────
AWS_REGION=us-west-2

# ── AgentCore ───────────────────────────────────────────────────────────────
WORKLOAD_NAME=obo-usecase1-entra-realworld
ACTOR_PROVIDER_NAME=obo-uc1-entra-realworld-actor

# Agent runtime name (used by the AgentCore CLI as the project name).
# CLI rules: ≤ 23 characters, must start with a letter, **alphanumeric only**
# (no underscores, no hyphens). Use camelCase to combine words.
AGENT_RUNTIME_NAME=oboUc1EntraAgent

# Populated by deploy/02_deploy_agent.py after the agent is deployed.
AGENT_RUNTIME_INVOKE_URL=
